{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "SqlDbConnection": "CPPGWApiServicesDBConnection",
    "ApplicationName": "OperationLogsApiNET8",
    "TrustServerCertificate": "True"
  },
  "DatabaseSettings": {
    "SqlDbSchema": "dbo"
  },
  "WebAppSetting": {
    "EnvServerMode": "BETA",
    "CHILLPAY_HEADER_KEY": "CHILLPAY-TOKEN",
    "CHILLPAY_TOKEN": "OPERATION_LOGS_CHILLPAY_TOKEN"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Graylog" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "D:\\logs\\ChillPayApisBeta\\ChillPayOperationLogsApiBETA.log",
                "restrictedToMinimumLevel": "Information",
                "fileSizeLimitBytes": 16485760,
                "rollOnFileSizeLimit": true,
                "retainedFileCountLimit": 100,
                "flushToDiskInterval": "00:03:00",
                "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [Action:{ActionName}, {TransactionId}] {Message:lj}{NewLine}{Exception}",
                "shared": true
              }
            },
            {
              "Name": "Graylog",
              "Args": {
                "hostnameOrAddress": "graylog.chillpay-prod.com",
                "transportType": "Udp",
                "port": "12201",
                "facility": "ChillPayOperationLogsApi",
                "minimumLogEventLevel": "Information"
              }
            }
          ]
        }
      }
    ],
    "Properties": {
      "Application": "ChillPayOperationLogsApi",
      "Release": "BETA"
    }
  },
  "AllowedHosts": "*"
}
