{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "SqlDbConnection": "CPPGWApiServicesDBConnectionSandbox",
    "ApplicationName": "OperationLogsApiNET8",
    "TrustServerCertificate": "True"
  },
  "DatabaseSettings": {
    "SqlDbSchema": "dbo"
  },
  "WebAppSetting": {
    "EnvServerMode": "SANDBOX",
    "CHILLPAY_HEADER_KEY": "CHILLPAY-TOKEN",
    "CHILLPAY_TOKEN": "OPERATION_LOGS_CHILLPAY_TOKEN"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Graylog" ],
    "LevelSwitches": {
      "$controlSwitch": "Information"
    },
    "MinimumLevel": {
      "ControlledBy": "$controlSwitch",
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "E:\\logs\\ChillPayApis-SandboxV3\\ChillPayOperationLogsApi-NET8.log",
                "restrictedToMinimumLevel": "Information",
                "fileSizeLimitBytes": 16485760,
                "retainedFileCountLimit": 50,
                "rollOnFileSizeLimit": true,
                "flushToDiskInterval": "00:03:00",
                "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [Action: {ActionName}, {CorrelationId}] {Message:lj}{NewLine}{Exception}",
                "shared": true
              }
            },
            {
              "Name": "Graylog",
              "Args": {
                "hostnameOrAddress": "dev-graylog.chillpay-prod.com",
                "port": "12201",
                "transportType": "Udp",
                "facility": "ChillPay.OperationLogs.Api",
                "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [RequestId:{RequestId}] [{RequestPath}] [{ActionName}] {Message:lj}{NewLine}{Exception}",
                "minimumLogEventLevel": "Information"
              }
            }
          ]
        }
      }
    ],
    "Properties": {
      "Application": "ChillPay.OperationLogs.Api",
      "Release": "Sandbox-Beta"
    }
  },
  "AllowedHosts": "*"
}
